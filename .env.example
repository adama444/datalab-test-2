# PostgreSQL (Metadata & Data Warehouse)
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=postgres
POSTGRES_DB=your_database_name
POSTGRES_PORT=5432

# Airflow
AIRFLOW_UID=1000
AIRFLOW_ADMIN_USERNAME=your_airflow_username
AIRFLOW_ADMIN_PASSWORD=your_airflow_password
AIRFLOW_ADMIN_EMAIL=your_email@example.com
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://your_postgres_user:your_postgres_password@postgres:5432/your_database_name
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here

# MinIO
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_CLEANED=cleaned

# Superset
SUPERSET_ADMIN_USERNAME=your_superset_username
SUPERSET_ADMIN_PASSWORD=your_superset_password
SUPERSET_ADMIN_EMAIL=your_email@example.com